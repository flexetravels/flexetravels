# ============================================================
# FlexeTravels Backend — Environment Variables
# Copy this file to backend/.env and fill in your API keys
# ============================================================

# ── REQUIRED: Claude AI (Anthropic) ─────────────────────────
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model selection (optional - defaults to claude-sonnet-4-20250514)
# Options: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── OPTIONAL: Flight & Hotel Search (Amadeus) ───────────────
# Get keys at: https://developers.amadeus.com/
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
# Currency preference for Amadeus searches (defaults to USD)
AMADEUS_CURRENCY=USD

# ── OPTIONAL: Payment Processing (Stripe) ───────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ── OPTIONAL: Web Search Fallback (Serper / Google Search) ────
# Get key at: https://serper.dev/ (free tier: 100 searches/month)
# Used as fallback when Amadeus has limited flight/hotel results
SERPER_API_KEY=

# ── OPTIONAL: Email Confirmations (Mailchimp) ───────────────
# Get keys at: https://mailchimp.com/developer/
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# ── OPTIONAL: Social Media (Buffer) ─────────────────────────
# Get token at: https://buffer.com/developers/
BUFFER_ACCESS_TOKEN=

# ── Server Config ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=*
