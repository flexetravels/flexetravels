# Copy to .env.local and fill in staging values

# Anthropic — use staging/test key
ANTHROPIC_API_KEY=sk-ant-...

# Existing FastAPI backend (staging Railway instance)
BACKEND_URL=https://flexetravels-staging.up.railway.app

# Duffel — use test mode key
DUFFEL_ACCESS_TOKEN=duffel_test_...

# Unsplash
UNSPLASH_ACCESS_KEY=...

# App
NEXT_PUBLIC_APP_URL=https://staging.flexetravels.com
NODE_ENV=development
